@page "/chat"
@using ChatBot.Share.Enums
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Chat — RAG Chatbot</PageTitle>

<div class="chat-page">

    <!-- ── Top Nav Bar ── -->
    <header class="chat-nav">
        <div class="chat-nav-left">
            <span class="nav-logo">
                <span class="material-symbols-rounded">auto_awesome</span>
                RAG Chat
            </span>
        </div>
        <div class="chat-nav-right">
            <div class="connection-pill @(GetConnectionStatus().ToLower().Replace(" ", "-"))">
                <span class="dot"></span>
                @GetConnectionStatus()
            </div>
            <a href="/rag" class="btn-nav">
                <span class="material-symbols-rounded">folder_open</span>
                Documents
            </a>
            <a href="/evaluation" class="btn-nav">
                <span class="material-symbols-rounded">science</span>
                Evaluation
            </a>
        </div>
    </header>

    <!-- ── Chat Body ── -->
    <main class="chat-main">

        <!-- Messages -->
        <div class="message-list" id="messageList">
            @if (_messages.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon-wrap">
                        <span class="material-symbols-rounded">chat_bubble</span>
                    </div>
                    <h2>How can I help you?</h2>
                    <p>Ask me anything about your uploaded documents, or just chat!</p>
                </div>
            }

            @foreach (var msg in _messages)
            {
                <div class="message @(msg.Role == MessageRole.User ? "user" : "assistant")">

                    @if (msg.Role == MessageRole.Assistant)
                    {
                        <div class="avatar assistant-avatar">
                            <span class="material-symbols-rounded">auto_awesome</span>
                        </div>
                    }

                    <div class="message-body">
                        <div class="message-content">
                            @if (msg.Role == MessageRole.Assistant)
                            {
                                @((MarkupString)RenderMarkdown(msg.Content))
                                @if (msg.IsStreaming)
                                {
                                    <span class="typing-cursor"></span>
                                }
                            }
                            else
                            {
                                @msg.Content
                            }
                        </div>

                        @if (msg.SourceDocuments.Count > 0)
                        {
                            <div class="message-sources">
                                <span class="material-symbols-rounded">menu_book</span>
                                @string.Join(", ", msg.SourceDocuments)
                            </div>
                        }

                        <div class="message-time">
                            @msg.Timestamp.ToLocalTime().ToString("HH:mm")
                        </div>
                    </div>

                    @if (msg.Role == MessageRole.User)
                    {
                        <div class="avatar user-avatar">
                            <span class="material-symbols-rounded">person</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Error Banner -->
        @if (_errorMessage is not null)
        {
            <div class="error-banner">
                <span class="material-symbols-rounded">warning</span>
                @_errorMessage
                <button @onclick="() => _errorMessage = null">
                    <span class="material-symbols-rounded">close</span>
                </button>
            </div>
        }

        <!-- Input Area — sticks to bottom -->
        <div class="chat-input-area">
            <div class="input-box">
                <textarea
                    id="chatTextarea"
                    class="chat-input"
                    placeholder="Message RAG Chat..."
                    value="@_userInput"
                    @oninput="HandleInputChange"
                    @onkeydown="HandleKeyDown"
                    disabled="@(!_isConnected || _isStreaming)"
                    rows="1">
                </textarea>
                <button class="btn-send"
                        @onclick="SendMessageAsync"
                        disabled="@(!_isConnected || _isStreaming || string.IsNullOrWhiteSpace(_userInput))">
                    @if (_isStreaming)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <span class="material-symbols-rounded">arrow_upward</span>
                    }
                </button>
            </div>
            <p class="input-hint">Press <kbd>Enter</kbd> to send &middot; <kbd>Shift+Enter</kbd> for new line</p>
        </div>

    </main>
</div>
